generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User Model ─────────────────────────────────────────────

model User {
  id       String  @id @default(cuid())
  name     String?
  email    String  @unique
  password String?
  image    String?

  conversations Conversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Agent Models ───────────────────────────────────────────

model Agent {
  id          String  @id @default(cuid())
  name        String  @unique
  displayName String?
  description String?
  entryPoint  String
  config      Json?
  enabled     Boolean @default(true)

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Chat Models ────────────────────────────────────────────

model Conversation {
  id     String  @id @default(cuid())
  title  String?
  userId String

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    Message[]
  canvasNodes CanvasNode[]
  canvasEdges CanvasEdge[]
  files       ConversationFile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ConversationFile {
  id             String @id @default(cuid())
  conversationId String
  filename       String
  originalName   String
  mimeType       String
  size           Int
  path           String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversationId])
}

model CanvasNode {
  id             String @id @default(cuid())
  conversationId String
  type           String // chart | image | pdf | text
  label          String @default("")
  positionX      Float  @default(0)
  positionY      Float  @default(0)
  width          Float  @default(320)
  height         Float  @default(240)
  data           Json?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId])
}

model CanvasEdge {
  id             String  @id @default(cuid())
  conversationId String
  sourceNodeId   String
  targetNodeId   String
  animated       Boolean @default(true)
  style          Json?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId])
}

model Message {
  id             String  @id @default(cuid())
  role           String
  content        String  @db.Text
  metadata       Json?
  conversationId String
  agentId        String?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agent        Agent?       @relation(fields: [agentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([agentId])
}

// ─── Task Models (reserved for async agent tasks) ───────────

model Task {
  id       String @id @default(cuid())
  type     String
  status   String @default("pending")
  input    Json?
  output   Json?
  error    String?
  agentId  String?
  userId   String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([status])
  @@index([userId])
}
