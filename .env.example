DB_IMAGE="docker.1ms.run/pgvector/pgvector:pg16"
NODE_IMAGE="docker.1ms.run/library/node:20-slim"

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pharma_alpha?schema=public"
DEEPSEEK_API_KEY="your-deepseek-api-key"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# LLM Configuration (optional, defaults to DeepSeek)
# LLM_BASE_URL="https://api.deepseek.com"
# LLM_API_KEY="your-llm-api-key"
# LLM_MODEL="deepseek-chat"

# Embedding Configuration
# EMBEDDING_PROVIDER="openai"  # openai | zhipu | dashscope | local
# EMBEDDING_API_KEY="your-embedding-api-key"
# EMBEDDING_MODEL="text-embedding-3-small"
# EMBEDDING_DIMENSIONS="1536"

# Platform API (auto-injected by executor, usually not needed)
# PLATFORM_API_BASE="http://localhost:3000/api"
